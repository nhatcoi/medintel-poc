# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://medintel:medintel@127.0.0.1:5432/medintel_orm
CREATE_TABLES_ON_STARTUP=true

# ── Security ──────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── LLM (OpenAI-compatible) ──────────────────────────────────
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
LLM_MAX_TOKENS=768
LLM_TEMPERATURE=0.3

# ── Chat ─────────────────────────────────────────────────────
CHAT_HISTORY_LIMIT=8
PATIENT_AGENT_CONTEXT_MAX_AGE_SECONDS=3600
PATIENT_AGENT_CONTEXT_MAX_MARKDOWN_CHARS=12000

# ── RAG ──────────────────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384
EMBEDDING_WARMUP_ON_STARTUP=true
RAG_TOP_K=6
RAG_MIN_SIMILARITY=0.72
RAG_CONTEXT_MAX_CHARS=3800

# ── CAG (Cache-Augmented Generation) ────────────────────────
CAG_ENABLED=true
CAG_DEFAULT_TTL_HOURS=24
KB_VERSION=1

# ── Tavily (external search fallback) ───────────────────────
TAVILY_API_KEY=
TAVILY_ENABLED=true
TAVILY_TIMEOUT_SECONDS=12

# ── Misc ─────────────────────────────────────────────────────
DEFAULT_PRESCRIPTION_USER_ID=00000000-0000-0000-0000-000000000001
DOCS_ENABLED=true
OPENAPI_PUBLIC_URL=http://localhost:8000
HTTP_ACCESS_LOG=true
HTTP_LOG_HEADERS=true
HTTP_LOG_BODIES=true
HTTP_LOG_BODY_MAX_CHARS=4000
AGENT_TRACE_LOG=true
AGENT_TRACE_MAX_CHARS=4000
