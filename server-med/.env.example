# Trùng POSTGRES_DB trong server-med/docker-compose.yml (mặc định medintel_orm)
DATABASE_URL=postgresql+psycopg2://medintel:medintel@127.0.0.1:5432/medintel_orm
# true = SQLAlchemy create_all khi khởi động (không dùng file SQL init trong container)
CREATE_TABLES_ON_STARTUP=true
JWT_SECRET=change-me-in-production

# LLM — mặc định Groq (OpenAI-compatible). Key: https://console.groq.com/keys
# Dùng GROQ_API_KEY hoặc LLM_API_KEY (cùng giá trị).
LLM_BASE_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_KEY=
# LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
# Quét đơn (ảnh) — model multimodal trên Groq; đổi nếu provider khác có vision
LLM_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Tối ưu latency chat: giới hạn token sinh (0 = tắt). RAG/ghép context xem RAG_CONTEXT_MAX_CHARS, RAG_TOP_K.
LLM_MAX_TOKENS=768
CHAT_HISTORY_LIMIT=8
# Markdown ngữ cảnh agent (bảng patient_agent_context): TTL làm mới tự động khi chat (giây)
PATIENT_AGENT_CONTEXT_MAX_AGE_SECONDS=3600
PATIENT_AGENT_CONTEXT_MAX_MARKDOWN_CHARS=12000
RAG_TOP_K=6
RAG_CONTEXT_MAX_CHARS=3800
# Nạp embedding khi start — tin chat/RAG đầu không chờ load model (pytest tắt)
EMBEDDING_WARMUP_ON_STARTUP=true
# UUID user để gán đơn khi app không gửi user_id (sau POST /auth/register copy id vào đây)
DEFAULT_PRESCRIPTION_USER_ID=

# CAG (Cache-Augmented Generation)
CAG_ENABLED=true
CAG_DEFAULT_TTL_HOURS=24
# Bump số này sau mỗi lần ingest dữ liệu RAG mới để invalidate cache cũ
KB_VERSION=1

# Agent 2 external fallback (Tavily Search)
TAVILY_API_KEY=
TAVILY_ENABLED=true
TAVILY_TIMEOUT_SECONDS=12

# Log HTTP: -> request, <- response (status + ms). Bật HTTP_LOG_BODIES chỉ khi dev (dễ lộ mật khẩu/token).
HTTP_ACCESS_LOG=true
HTTP_LOG_HEADERS=false
HTTP_LOG_BODIES=false
HTTP_LOG_BODY_MAX_CHARS=2048
