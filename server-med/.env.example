# Trùng POSTGRES_DB trong server-med/docker-compose.yml (mặc định medintel_orm)
DATABASE_URL=postgresql+psycopg2://medintel:medintel@127.0.0.1:5432/medintel_orm
# true = SQLAlchemy create_all khi khởi động (không dùng file SQL init trong container)
CREATE_TABLES_ON_STARTUP=true
JWT_SECRET=change-me-in-production

# Quét đơn thuốc (AI Vision)
LLM_BASE_URL=https://rftzycu.9router.com/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=combo-2
# UUID user để gán đơn khi app không gửi user_id (sau POST /auth/register copy id vào đây)
DEFAULT_PRESCRIPTION_USER_ID=

# CAG (Cache-Augmented Generation)
CAG_ENABLED=true
CAG_DEFAULT_TTL_HOURS=24
# Bump số này sau mỗi lần ingest dữ liệu RAG mới để invalidate cache cũ
KB_VERSION=1

# Agent 2 external fallback (Tavily Search)
TAVILY_API_KEY=
TAVILY_ENABLED=true

# Log HTTP: -> request, <- response (status + ms). Bật HTTP_LOG_BODIES chỉ khi dev (dễ lộ mật khẩu/token).
HTTP_ACCESS_LOG=true
HTTP_LOG_HEADERS=false
HTTP_LOG_BODIES=false
HTTP_LOG_BODY_MAX_CHARS=2048
